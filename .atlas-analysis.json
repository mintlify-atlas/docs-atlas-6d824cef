  "keyFeatures": [
    "SPARQL 1.1 knowledge graph query and update engine",
    "Neuro-symbolic hybrid search (vector + keyword + graph filters)",
    "AI SDK integration with first-class LLM tool-calling support",
    "Edge-first architecture powered by Deno and Turso (libSQL)",
    "RDF import/export (Turtle, N-Quads, N-Triples, N3)",
    "Persistent structured agent memory across sessions",
    "TypeScript SDK published to JSR (@wazoo/worlds-sdk)",
    "Command-line interface for world management",
    "Worlds Console web UI for visual graph exploration",
    "Provider-agnostic: works with any LLM or agent framework"
  ],
  "publicApiSurface": [
    "WorldsSdk",
    "WorldsSdk.worlds.list(options?)",
    "WorldsSdk.worlds.get(id)",
    "WorldsSdk.worlds.create(params)",
    "WorldsSdk.worlds.update(id, params)",
    "WorldsSdk.worlds.delete(id)",
    "WorldsSdk.worlds.sparql(id, query, options?)",
    "WorldsSdk.worlds.search(id, query, options?)",
    "WorldsSdk.worlds.import(id, data, options?)",
    "WorldsSdk.worlds.export(id, options?)",
    "WorldsSdk.worlds.listLogs(id, options?)",
    "createTools({ sdk, sources }) — AI SDK tool factory",
    "worlds create --label <label>",
    "worlds list",
    "worlds get <worldId>",
    "worlds update <worldId>",
    "worlds delete <worldId>",
    "worlds sparql <worldId> <query>",
    "worlds search <worldId> <query>",
    "worlds import <worldId> <file>",
    "worlds export <worldId>",
    "worlds chat --worldId <id>",
    "GET /worlds",
    "POST /worlds",
    "GET /worlds/:world",
    "PUT /worlds/:world",
    "DELETE /worlds/:world",
    "POST /worlds/:world/sparql",
    "GET /worlds/:world/search",
    "POST /worlds/:world/import",
    "GET /worlds/:world/export",
    "GET /worlds/:world/logs"
  ]
